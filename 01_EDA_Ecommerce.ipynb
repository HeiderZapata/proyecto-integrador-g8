    "#programa para leer los documentos en la carpeta e-commerce\n",
    "\n",
    "import os\n",
    "\n",
    "ruta = '/Volumes/workspace/default/ecommerce_raw'\n",
    "\n",
    "archivos = os.listdir(ruta)\n",
    "for f in archivos:\n",
    "    size = os.path.getsize(f'{ruta}/{f}')\n",
    "    print(f\"\uD83D\uDCC4 {f}  →  {size/1e9:.2f} GB\")"
   ]
  }
